 # <system>
# You are a filesystem assistant.
# </system>
     
.PHONY: list-files greet write-file

# <tool>
# List files in a directory.
# @param DIR string The directory path to list
# </tool>
list-files:
	@ls -la $(DIR)

# <tool>
# Greet someone.
# @param NAME string The name to greet
# </tool>
greet:
	@echo "Hello, $(NAME)!"
	#
# <tool>
# Git command
# @param FLAGS string The git command flags
# </tool>
git:
	@git $(FLAGS)

# <tool>
# Write text content to a file. Use this for any multi-line content such as
# scripts, configuration files, or source code.
# @param FILE string Destination file path
# @param CONTENT content Text to write to the file
# </tool>
write-file:
	@mkdir -p "$(shell dirname $(FILE))"
	@cat "$(CONTENT_FILE)" > "$(FILE)"

